import os
import sys
from rembg import remove, new_session
from PIL import Image, ImageFile

# 允许 PIL 读取部分截断但仍可恢复的图片，避免批处理因为单张图片轻微损坏而中断。
ImageFile.LOAD_TRUNCATED_IMAGES = True

def process_image(input_path, output_path, session):
    """读取单张图片，使用 rembg 去背景，并保存为带 alpha 通道的 PNG。"""

    print(f"正在处理: {input_path}")
    try:
        with Image.open(input_path) as img:
            # 统一转为 RGBA，确保输出图片一定有透明通道。
            img = img.convert("RGBA")
            
            output_img = remove(
                img,
                session=session,
                alpha_matting=False,           # 关闭，避免过度扣除
                alpha_matting_foreground_threshold=240,
                alpha_matting_background_threshold=10,
                alpha_matting_erode_size=10,
                post_process_mask=True,        # 对 mask 做后处理，边缘更干净
            )
            
            # 去背景结果保存为 PNG，文件名会带 _no_bg，供 Electron 动作扫描逻辑识别使用。
            output_img.save(output_path, "PNG")
            print(f"✅ 成功保存到: {output_path}")

    except Exception as e:
        print(f"处理失败 {input_path}: {e}")

def process_folder(input_dir, output_dir):
    """批量处理输入目录里的图片，把透明背景结果输出到指定目录。"""

    if not os.path.exists(output_dir):
        os.makedirs(output_dir)
        print(f"创建输出文件夹: {output_dir}")

    # 用 u2net 模型，专门针对主体（动物效果更好）
    # 可选模型: "u2net", "u2net_human_seg", "isnet-general-use"
    session = new_session("isnet-general-use")

    valid_extensions = ('.jpg', '.jpeg', '.png', '.bmp', '.webp')
    processed_count = 0

    # 逐个处理支持的图片格式；非图片文件会被自动忽略。
    for filename in os.listdir(input_dir):
        if filename.lower().endswith(valid_extensions):
            input_path = os.path.join(input_dir, filename)
            file_base = os.path.splitext(filename)[0]
            output_filename = f"{file_base}_no_bg.png"
            output_path = os.path.join(output_dir, output_filename)
            
            process_image(input_path, output_path, session)
            processed_count += 1
            
    if processed_count == 0:
        print(f"在 {input_dir} 中没有找到有效的图片文件。")
    else:
        print(f"🎉 批量处理完成，共处理 {processed_count} 张图片。")

if __name__ == "__main__":
    # 默认处理 eat 动作原始帧。需要处理其他动作时改 input_folder / output_folder。
    input_folder = "./cat_anime/flames/eat"
    output_folder = "./transparent_cats"

    print("--- AI 抠图脚本启动 ---")
    
    # 如果输入目录不存在，就创建目录并提示用户先放入待处理图片。
    if not os.path.exists(input_folder):
        os.makedirs(input_folder)
        print(f"已自动创建 '{input_folder}'，请放入图片后重新运行。")
    else:
        process_folder(input_folder, output_folder)
        
    print("--- 脚本运行结束 ---")
